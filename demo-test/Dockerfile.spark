FROM eclipse-temurin:11-jre-jammy

ARG SPARK_VERSION=3.3.2
ARG HADOOP_VERSION=3
ARG SPARK_HOME=/opt/spark

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    tar \
    python3 \
    python3-distutils \
    python3-pip \
    openjdk-11-jre-headless \
    && rm -rf /var/lib/apt/lists/*

# Download Spark with fallback to archive
RUN set -eux; \
    SPARK_TGZ="spark-${SPARK_VERSION}-bin-hadoop${HADOOP_VERSION}.tgz"; \
    URL_PRIMARY="https://downloads.apache.org/spark/spark-${SPARK_VERSION}/${SPARK_TGZ}"; \
    URL_FALLBACK="https://archive.apache.org/dist/spark/spark-${SPARK_VERSION}/${SPARK_TGZ}"; \
    if ! curl -fSL "$URL_PRIMARY" -o /tmp/${SPARK_TGZ}; then \
      curl -fSL "$URL_FALLBACK" -o /tmp/${SPARK_TGZ}; \
    fi; \
    mkdir -p ${SPARK_HOME}; \
    tar -xzf /tmp/${SPARK_TGZ} -C /opt; \
    mv /opt/spark-${SPARK_VERSION}-bin-hadoop${HADOOP_VERSION} ${SPARK_HOME}; \
    rm /tmp/${SPARK_TGZ}

ENV SPARK_HOME=${SPARK_HOME}
ENV PATH=${SPARK_HOME}/bin:${PATH}

# install python libs used by the spark job
RUN python3 -m pip install --no-cache-dir pyspark==3.3.2 delta-spark==2.2.0 kafka-python

WORKDIR /opt/project

CMD ["/bin/bash", "-c", "sleep infinity"]
FROM eclipse-temurin:11-jre-jammy

ARG SPARK_VERSION=3.3.2
ARG HADOOP_VERSION=3

RUN apt-get update && apt-get install -y curl wget tar python3 python3-pip && rm -rf /var/lib/apt/lists/*

WORKDIR /opt
# Download prebuilt Spark (hadoop3) with retries and clearer failure handling
RUN set -eux; \
    SPARK_TGZ="spark-${SPARK_VERSION}-bin-hadoop3.tgz"; \
    SPARK_URL="https://downloads.apache.org/spark/spark-${SPARK_VERSION}/${SPARK_TGZ}"; \
    SPARK_URL_FALLBACK="https://archive.apache.org/dist/spark/spark-${SPARK_VERSION}/${SPARK_TGZ}"; \
    curl -fSL --retry 5 --retry-delay 5 -o "${SPARK_TGZ}" "${SPARK_URL}" || \
    curl -fSL --retry 5 --retry-delay 5 -o "${SPARK_TGZ}" "${SPARK_URL_FALLBACK}"; \
    tar xzf "${SPARK_TGZ}"; \
    mv "spark-${SPARK_VERSION}-bin-hadoop3" spark; \
    rm -f "${SPARK_TGZ}"

ENV SPARK_HOME=/opt/spark
ENV PATH=$SPARK_HOME/bin:$PATH

# Install pyspark (so spark-submit can run Python jobs)
RUN pip3 install pyspark==3.3.2 delta-spark==2.2.0 kafka-python

# Create a non-root user
RUN useradd -ms /bin/bash spark
USER spark
WORKDIR /opt/project

# Keep container alive; Airflow will exec spark-submit inside
CMD ["/bin/bash", "-c", "sleep infinity"]
